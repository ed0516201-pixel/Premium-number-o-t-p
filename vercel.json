{
  "version": 2,
  "buildCommand": "pnpm install && pnpm --filter @workspace/db run push && pnpm --filter @workspace/otp-dashboard run build",
  "outputDirectory": "artifacts/otp-dashboard/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "env": {
    "BASE_PATH": "/"
  }
}
